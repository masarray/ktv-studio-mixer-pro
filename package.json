{
  "name": "sonkupik-karaoke-studio",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "presets:generate": "node scripts/generate-builtin-presets.mjs",
    "presets:catalog": "node scripts/generate-preset-catalog.mjs",
    "presets:catalog:check": "node scripts/generate-preset-catalog.mjs --check",
    "presets:prepare": "npm run presets:generate && npm run presets:catalog",
    "desktop:prepare": "node scripts/prepare-electron-build.mjs",
    "test:electron-metadata": "node scripts/test-electron-build-metadata.mjs",
    "test:windows-packaging": "node scripts/test-windows-packaging-config.mjs",
    "test:system-layout": "node scripts/test-system-layout.mjs",
    "test:ux-controls": "node scripts/test-ux-controls.mjs",
    "test:v0842-hardening": "node scripts/test-v0842-hardening.mjs",
    "test:v0843-performance": "node scripts/test-v0843-performance.mjs",
    "test:preset-catalog": "node scripts/test-preset-catalog.mjs",
    "pretest:builtin-presets": "npm run presets:generate",
    "test:builtin-presets": "node scripts/test-builtin-presets.mjs",
    "prebuild": "npm run presets:prepare",
    "dev": "vite dev",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "bridge": "node tools/k500-bridge.mjs",
    "desktop": "npm run build && electron .",
    "predist:portable": "npm run desktop:prepare",
    "dist:portable": "npm run build && electron-builder --win portable --x64 --publish never",
    "predist:installer": "npm run desktop:prepare",
    "dist:installer": "npm run build && electron-builder --win nsis --x64 --publish never",
    "predist:windows": "npm run desktop:prepare",
    "dist:windows": "npm run build && electron-builder --win portable nsis --x64 --publish never",
    "test:desktop-server": "node scripts/test-desktop-server.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
